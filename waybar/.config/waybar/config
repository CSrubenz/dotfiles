{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 8,
    "exclusive": true,

    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "network", "pulseaudio", "custom/battery_merged", "tray"],

    // left
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "active": "",
            "default": ""
        },
        "sort-by-number": true
    },

    "hyprland/window": {
        "max-length": 50
    },

    // center
    "clock": {
        "format": "  {:%H:%M    %d/%m/%Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    // right
    "cpu": {
        "interval": 2,
        "format": " {usage}%",
        "tooltip": true
    },

    "memory": {
        "interval": 2,
        "format": " {}%",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G"
    },

    "network": {
        "format-wifi": "🛜  {essid}",
        "format-ethernet": "🌐  Wired",
        "format-disconnected": "✈️  Offline",
        "on-click": "nm-connection-editor"
    },

    "pulseaudio": {
        "format": "{icon} {volume}% ",
        "format-bluetooth": "{icon} {volume}%",
        "format-muted": " ",
        "format-icons": {
            "headphone": " ",
            "default": [" ", " "]
        },
        "on-click": "pavucontrol"
    },

    "custom/battery_merged": {
        "exec": "~/.config/waybar/battery_merged.sh",
        "return-type": "json",
        "interval": 5,
        "format": "{text}"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 10
    }

}


